# 자격증명 — 서비스 계정 키/시크릿은 절대 커밋 금지
*.json
.env
*.key
*.pem
# 단, evals 케이스 데이터(JSON)는 추적한다(자격증명 아님)
!evals/cases/
!evals/cases/*.json

# OS / 에디터 부산물
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.pytest_cache/

# 로컬 SQLite 산출물 / 자동 캐시(파생물 — 절대 커밋 금지)
*.db
*.sqlite
.eb-cache.sqlite
**/.eb-cache.sqlite

# web 앱 배포 시 생성되는 CSV 복사본(파생물)
web/data/
